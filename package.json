{
  "name": "ledgard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:govard": "vite --host 0.0.0.0 --port 80",
    "dev:worker": "wrangler dev --local --port 8787",
    "dev:worker:govard": "wrangler dev --local --ip 0.0.0.0 --port 8787",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply ledgard-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ledgard-db --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@tanstack/react-query": "^5.62.7",
    "date-fns": "^4.1.0",
    "hono": "^4.6.16",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "vite-plugin-pwa": "^0.21.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "wrangler": "^4.97.0",
    "xlsx": "^0.18.5"
  }
}
